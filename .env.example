# Copia este archivo a .env y completa con los valores de tu proyecto Supabase
# (Dashboard > Settings > API). Es la MISMA instancia que ZenTask: las tablas
# de finanzas usan prefijo fin_ y su propio RLS. La anon key es pública por
# diseño, pero igual no se commitea: cada entorno define la suya.
EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
